# Postgres connection
DATABASE_URL=postgresql://user@localhost/agentry

# Dune Analytics
DUNE_API_KEY=your_dune_api_key_here

# BaseScan API
BASESCAN_API_KEY=your_basescan_api_key_here

# Alchemy
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Azure AI Foundry / GitHub Models (Foundry IQ integration)
# Generate at: github.com → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=your_github_pat_here

# CORS (production: set to your frontend domain)
ALLOWED_ORIGINS=https://your-domain.com
